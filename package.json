{
  "name": "openclaw-clawvc",
  "version": "1.0.0",
  "type": "module",
  "description": "Git-based workspace version control for OpenClaw — auto-commit, undo, and plan mode",
  "license": "MIT",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.0",
    "chokidar": "^4.0.0",
    "json5": "^2.2.3"
  },
  "devDependencies": {
    "@types/json5": "^0.0.30",
    "@types/node": "^25.5.2",
    "typescript": "^5.7.0"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "skills": [
      "./skills"
    ],
    "compat": {
      "pluginApi": ">=2026.4.4"
    }
  }
}
